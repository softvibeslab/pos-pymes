# Production Environment Variables for Hostinger VPS
# Copia este archivo a .env y actualiza con tus valores

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ============================================
# BASE DE DATOS
# ============================================
# Ruta de la base de datos SQLite en el VPS
DATABASE_PATH=/app/data/local.db

# ============================================
# CORS - Permitir acceso desde tu dominio
# ============================================
# Reemplaza con tu dominio real
CORS_ORIGIN=https://tu-dominio.com,https://www.tu-dominio.com

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info

# ============================================
# NEXT.JS - Variables de entorno del frontend
# ============================================
# URL de la API en producción (cambiar 'tu-dominio.com' por tu dominio real)
NEXT_PUBLIC_API_URL=https://tu-dominio.com/api
